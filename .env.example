# Copy to .env (the file `install.sh` reads) and fill in your values.
# The .env file is gitignored — never commit real secrets.

# Required ────────────────────────────────────────────────────────────────────
# Your Dot. device serial (shown in the Dot. mobile app).
DOT_DEVICE_ID=

# Your Dot. API key (Dot. app → Developer settings).
DOT_API_KEY=

# Optional ────────────────────────────────────────────────────────────────────
# Name shown in the bottom-left footer. Leave blank to hide it entirely.
DOT_OWNER_NAME=

# IANA timezone for the "Updated HH:MM ..." stamp. Defaults to UTC.
# Examples: Asia/Dubai, America/New_York, Europe/Paris, Asia/Shanghai.
DOT_TZ=UTC

# Optional abbreviation to show after the time (e.g. "GST", "EST", "CET").
# Leave blank to auto-detect from the IANA zone — note that modern tzdata
# often returns numeric offsets like "+04" instead of friendly abbreviations.
DOT_TZ_ABBR=

# How often the script runs, in seconds. launchd default here is 600 (10 min).
DOT_INTERVAL_SECONDS=600

# Flag the footer with a stale-data dot if OpenUsage data is older than this
# many seconds. Default 900 (15 minutes).
DOT_STALE_SECONDS=900
